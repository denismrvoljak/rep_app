<h1> <%= @workout.name%> </h1>
<p> <%= @workout.notes%> </p>
<%= link_to "Edit workout", edit_workout_path(@workout), class: "button" %>
<% @workout.workout_exercises.each do |entry| %>
  <div class="exercise-entry">
    <%= entry.exercise.name %>
    <span><%= entry.weight %> · <%= entry.sets %> × <%= entry.reps %></span>
  </div>
<% end %>
<h2> Add exercise </h2>
<%= form_with model: [@workout, WorkoutExercise.new] do |form| %>
  <%= form.label :exercise_id, "Exercise" %>
  <%= form.collection_select :exercise_id, Exercise.all, :id, :name %>

  <%= form.label :weight %>
  <%= form.text_field :weight %>

  <%= form.label :sets %>
  <%= form.text_field :sets %>

  <%= form.label :reps %>
  <%= form.text_field :reps %>
  <%= form.submit "Add exercise" %>
<% end %>

<div class="workout-actions">
<%= link_to "Delete workout", @workout, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "button" %>
<%= link_to "Back to workouts", workouts_path, class: "button" %>
</div>
